{{!-- Контейнер для PathfinderBestiarySettingsMenu (Меню настроек) --}}
{{#if isSettingsForm}}
  <form class="settings-menu" id="settings-menu">
    <div class="scrollable-content">
      <p>{{{enrichedSettingsMessage}}}</p>
      <div class="form-group">
        <label><input type="checkbox" id="toggle-check-buttons" /> {{localize "SettingCompendiums.EnableCheckMode"}}</label>
      </div>
      {{#each groups}}
        <div class="category-section">
          <h2>{{localize (concat "SettingCompendiums." @key)}}</h2><hr />
          {{#each this}}
            <div class="form-group">
              <label for="{{settingKey}}">{{name}}</label>
              <button type="button" class="check-button" data-key="{{key}}">{{localize "SettingCompendiums.CheckButtonLabel"}}</button>
              <input type="checkbox" id="{{settingKey}}" name="{{settingKey}}" {{#if value}}checked{{/if}} />
            </div>
            {{#if hint}}<p class="hint">{{hint}}</p>{{/if}}
          {{/each}}
        </div>
      {{/each}}
    </div>
    <div class="form-footer">
      <button type="submit" class="button">{{localize "SettingCompendiums.SaveAndUpdate"}}</button>
    </div>
    <style>
      #pf2e-token-pack-settings { width: 720px !important; height: 1450px !important; }
      .settings-menu { font-family: 'Noto Sans', 'Segoe UI', sans-serif; font-weight: 500; height: 100%; display: flex; flex-direction: column; }
      .settings-menu .scrollable-content { overflow-y: auto; flex: 1; padding: 0px 8px 0px 0px; }
      .settings-menu .category-section { border: 1px solid #555; border-radius: 8px; padding: 15px; margin-bottom: 20px; }
      .settings-menu .category-section hr { border: none; border-top: 1px solid #c92c2c; margin: 10px 0 15px 0; }
      .settings-menu .form-group { display: flex; align-items: center; margin-bottom: 8px; }
      .settings-menu .form-group label { flex: 1; font-size: 1.1em; padding-right: 10px; }
      .settings-menu .check-button { visibility: hidden; margin-right: 8px; transition: none !important; }
      .settings-menu.show-check-buttons .check-button { visibility: visible; }
      .settings-menu .form-group input[type="checkbox"] { flex-shrink: 0; }
      .settings-menu .hint { margin: -4px 0 8px 10px; font-size: 0.9em; }
      .settings-menu .form-footer { flex-shrink: 0; padding: 0px 0px 0px 0px; border-top: 1px solid var(--color-border-light-tertiary); background-color: var(--color-bg); box-shadow: 0 -4px 8px rgba(0, 0, 0, 0.05); z-index: 1; }
      .settings-menu .form-footer button { width: 100%; }
    </style>
  </form>
{{/if}}

 {{!-- Контейнер для BestiaryCheckResultsDialog (Окно проверки) --}}
  {{#if isCheckResultsDialog}}
    <form class="check-results-form" id="check-results-form">
      <div class="scrollable-content">
        <div class="check-results-container">
          <details><summary>{{localize "SettingCompendiums.CheckSummaryDead"}} ({{summaries.dead}})</summary><div class="content-wrapper"><ul>{{{lists.dead}}}</ul></div></details>
          <details><summary>{{localize "SettingCompendiums.CheckSummaryMissingModule"}} ({{summaries.missingModule}})</summary><div class="content-wrapper"><ul>{{{lists.missingModule}}}</ul></div></details>
          <details><summary>{{localize "SettingCompendiums.CheckSummaryMissingImages"}} ({{summaries.missingImages}})</summary>
              <div class="image-sub-container">
                  <details><summary>{{localize "SettingCompendiums.CheckImgTypeArt"}} ({{imageCounts.art}})</summary><div class="image-sub-content"><ul>{{{lists.art}}}</ul></div></details>
                  <details><summary>{{localize "SettingCompendiums.CheckImgTypeToken"}} ({{imageCounts.token}})</summary><div class="image-sub-content"><ul>{{{lists.token}}}</ul></div></details>
                  <details><summary>{{localize "SettingCompendiums.CheckImgTypeRing"}} ({{imageCounts.ring}})</summary><div class="image-sub-content"><ul>{{{lists.ring}}}</ul></div></details>
              </div>
          </details>
          <details><summary>{{localize "SettingCompendiums.CheckSummaryUnused"}} ({{summaries.unused}})</summary>
              <div class="content-wrapper">
                  <p><em><small>{{localize "SettingCompendiums.ManualDeleteNote"}}</small></em></p>
                  <ul>{{{lists.unused}}}</ul>
              </div>
          </details>
        </div>
      </div>
      <div class="form-footer">
        {{!-- Этот блок будет автоматически заполнен кнопками из JS-класса BestiaryCheckResultsDialog --}}
      </div>
      <style>
          #pf2e-token-pack-check-results {  width: 600px !important; height: 750px !important; }
          .check-results-form { display: flex; flex-direction: column; height: 100%; }
          .check-results-form .scrollable-content { overflow-y: auto; flex: 1; padding: 0px 8px 0px 0px; }
          .check-results-form .form-footer { flex-shrink: 0; padding: 0px 0px 0px 0px; border-top: 1px solid var(--color-border-light-tertiary); background-color: var(--color-bg); display: flex; justify-content: center; gap: 8px; }
          .check-results-form .form-footer button { font-size: 1.05em; padding: 6px 12px; flex: 1; }
          .check-results-container details { border: none; margin-bottom: 10px; }
          .check-results-container summary { font-size: 1.15em; font-weight: bold; padding: 8px 12px; background-color: rgba(0, 0, 0, 0.2); border: 1px solid #777; border-radius: 5px; cursor: pointer; margin-bottom: 5px; }
          .check-results-container summary:hover { border-color: #ccc; }
          .check-results-container .content-wrapper { max-height: 450px; overflow-y: auto; padding: 5px 15px; }
          .check-results-container .image-sub-content { max-height: 250px; overflow-y: auto; padding: 5px 15px; }
          .check-results-container .image-sub-container { padding: 5px; border-top: 1px solid #444; margin-top: 5px; }
          .check-results-container .image-sub-container details { border-color: #555; margin-left: 10px; }
          .check-results-container .image-sub-container summary { background-color: rgba(0, 0, 0, 0.3); padding: 8px; font-size: 1.05em; }
          .check-results-container ul { list-style-type: none; padding-left: 0; margin: 0; }
          .check-results-container li { padding: 5px 0; border-bottom: 1px solid #282828; }
          .check-results-container li:last-child { border-bottom: none; }
          .check-results-container li.folder-header { padding: 8px 4px; background-color: rgba(0, 0, 0, 0.3); border-top: 1px solid #444; border-bottom: 1px solid #444; margin-top: 10px; }
          .check-results-container ul > li.folder-header:first-child { margin-top: 0; }
          .check-results-container li.folder-header h3 { margin: 0; font-size: 1.1em; }
          .check-results-container li small { display: inline-block; user-select: text; cursor: text; background-color: rgba(0, 0, 0, 0.25); padding: 2px 6px; border-radius: 4px; margin-top: 4px; font-family: 'Courier New', Courier, monospace; font-size: 0.9em; border: 1px solid rgba(255, 255, 255, 0.1); }
      </style>
    </form>
{{/if}}

{{!-- Контейнер для диалога "Все в порядке" --}}
{{#if isAllValidDialog}}
  <div>
    <p style="text-align: center; font-size: 1.2em;">{{localize "SettingCompendiums.AllValid"}}</p>
    {{#if isOrderDifferent}}
      <p style="text-align: center; color: var(--color-text-dark-primary);">{{localize "SettingCompendiums.CheckSortNeeded"}}</p>
    {{/if}}
  </div>
{{/if}}

{{!-- Контейнер для диалога "Перезагрузка" --}}
{{#if isReloadDialog}}
  <div>
    <p>{{localize "SettingCompendiums.BestiaryUpdatedMessage"}}</p>
  </div>
{{/if}}